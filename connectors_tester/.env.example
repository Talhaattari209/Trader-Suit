# connectors_tester/.env.example
# Copy to .env and fill in your credentials before running.
# This file is safe to commit — it contains NO real keys.

# ── Alpaca Account 1 (primary paper) ─────────────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2

# ── Alpaca Account 2 (secondary paper) ────────────────────────────────────────
ALPACA_API_KEY_2=your_api_key_2_here
ALPACA_SECRET_KEY_2=your_secret_key_2_here
ALPACA_ENDPOINT_2=https://paper-api.alpaca.markets/v2

# ── Alpaca MCP Server (alpaca-mcp sidecar — optional, enhances the agent) ────
# The official Alpaca MCP server exposes all broker operations as MCP tools.
# Run it with: npx @alpaca-markets/mcp-server --port 3001
# Leave blank if not running the MCP sidecar.
ALPACA_MCP_URL=http://localhost:3001

# ── MT5 (Windows-only) ───────────────────────────────────────────────────────
# Leave blank if not using MT5.  On non-Windows systems MT5 is silently disabled.
MT5_LOGIN=0
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server
MT5_PATH=                       # optional: C:\Program Files\MetaTrader 5\terminal64.exe

# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Data ─────────────────────────────────────────────────────────────────────
# Path to US30 CSV for price-level detection (optional)
US30_CSV_PATH=

# ── Database ─────────────────────────────────────────────────────────────────
# Where to store JSON files (strategies, positions, trades)
# Default: DataStore/  (relative to connectors_tester/)
AGENT_DATASTORE_PATH=DataStore
