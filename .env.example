# Vault and paths
VAULT_PATH=AI_Employee_Vault
US30_CSV_PATH=C:\Users\User\Downloads\claude\Dataset-Testing-US30\usa30idxusd-m5-bid-2025-10-09-2025-11-29.csv

# API Connectors (Pluggable Senses): alpaca | mt5 (MT5 is Windows-only; on WSL use a Windows bridge)
BROKER_TYPE=alpaca

# Alpaca – Primary account
ALPACA_API_KEY=your_key
ALPACA_SECRET_KEY=your_secret
ENDPOINT=https://paper-api.alpaca.markets/v2

# Alpaca – Backup account (multi-account failover; used when primary is rate-limited)
# ALPACA_API_KEY_2=your_second_key
# ALPACA_SECRET_KEY_2=your_second_secret

# Optional: max fraction of equity per order for risk check (default 0.1)
# CONNECTOR_MAX_RISK_FRACTION=0.1

# Advanced connector settings
# ALPACA_MAX_ORDERS_PER_MIN=200       # Token-bucket rate limit
# ORDER_BATCH_WINDOW_MS=500           # Batch window for combining orders

# Cache (default: in-memory only with 60s TTL)
# CACHE_TTL_SECONDS=60
# CACHE_DIR=                          # Set a path for disk-backed cache

# Optional: DataIngestionWatcher can fetch OHLCV from connector when set
# USE_CONNECTOR_FETCH=0
# CONNECTOR_SYMBOL=US30
# CONNECTOR_TIMEFRAME=1h
# CONNECTOR_COUNT=500

# Intelligence Layer (Librarian, Strategist)
GEMINI_API_KEY=your_gemini_key

# Optional: where watchers look for new research/data (default: vault/Needs_Action/ResearchInput, .../DataSource)
# RESEARCH_INPUT_PATH=AI_Employee_Vault/Needs_Action/ResearchInput
# DATA_SOURCE_PATH=AI_Employee_Vault/Needs_Action/DataSource

# Database (Neon) — required for run_workflow.py DB logging
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
